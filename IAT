private struct CustomPreset: Identifiable, Codable, Hashable {
    let id: UUID
    var positiveText: String
    var negativeText: String
    var yyText: String
    var zzText: String
    var updatedAt: Date

    var displayName: String {
        let left = yyText.trimmingCharacters(in: .whitespacesAndNewlines)
        let right = zzText.trimmingCharacters(in: .whitespacesAndNewlines)
        if left.isEmpty && right.isEmpty {
            return "未命名"
        }
        return "\(left.isEmpty ? "yy" : left)/\(right.isEmpty ? "zz" : right)"
    }
}

private enum CustomPresetStore {
    private static let storageKey = "IAT_CustomPresets"

    static func load() -> [CustomPreset] {
        guard let data = UserDefaults.standard.data(forKey: storageKey),
              let presets = try? JSONDecoder().decode([CustomPreset].self, from: data) else {
            return []
        }
        return presets
    }

    static func save(_ presets: [CustomPreset]) {
        guard let data = try? JSONEncoder().encode(presets) else { return }
        UserDefaults.standard.set(data, forKey: storageKey)
    }
}

private struct CustomWordConfig: Hashable {
    let positives: [String]
    let negatives: [String]
    let yyText: String
    let zzText: String
}

private struct HomeView: View {
    @State private var conceptText: String = ""
    @State private var showCustomSheet: Bool = false
    @State private var customPositiveText: String = ""
    @State private var customNegativeText: String = ""
    @State private var customYYText: String = ""
    @State private var customZZText: String = ""
    @State private var presets: [CustomPreset] = []

    var body: some View {
        VStack(spacing: 44) {
            Text("你要测试态度的概念")
                .font(.title)
                .fontWeight(.semibold)

            TextField("输入测试目标（例如：环保）", text: $conceptText)
                .textFieldStyle(.roundedBorder)
                .frame(maxWidth: 380)

            NavigationLink {
                InstructionView(
                    concept: conceptText,
                    isPreciseMode: true,
                    customConfig: resolvedCustomConfig
                )
            } label: {
                Text("开始")
                    .frame(width: 160, height: 48)
            }
            .buttonStyle(.borderedProminent)
            .disabled(conceptText.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty)

            Button("自定义") {
                showCustomSheet = true
            }
            .frame(width: 160, height: 44)
            .buttonStyle(.bordered)

            VStack(spacing: 6) {
                Text("测试会记录反应时与正确率")
                Text("请使用键盘按键作答")
                Text("建议在安静环境完成")
            }
            .font(.system(size: 18))
            .foregroundStyle(.secondary)

        }
        .padding(32)
        .navigationTitle("IAT 测试")
        .onAppear {
            presets = CustomPresetStore.load()
        }
        .sheet(isPresented: $showCustomSheet) {
            CustomSheetView(
                isPresented: $showCustomSheet,
                positiveText: $customPositiveText,
                negativeText: $customNegativeText,
                yyText: $customYYText,
                zzText: $customZZText,
                presets: $presets
            )
        }
    }

    private var resolvedCustomConfig: CustomWordConfig? {
        let positives = parseWords(from: customPositiveText)
        let negatives = parseWords(from: customNegativeText)
        if positives.isEmpty && negatives.isEmpty && customYYText.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty && customZZText.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty {
            return nil
        }
        return CustomWordConfig(
            positives: positives,
            negatives: negatives,
            yyText: customYYText.trimmingCharacters(in: .whitespacesAndNewlines),
            zzText: customZZText.trimmingCharacters(in: .whitespacesAndNewlines)
        )
    }

    private func parseWords(from text: String) -> [String] {
        let separators = CharacterSet(charactersIn: ",，;\n /／")
        return text
            .components(separatedBy: separators)
            .map { $0.trimmingCharacters(in: .whitespacesAndNewlines) }
            .filter { !$0.isEmpty }
    }
}

