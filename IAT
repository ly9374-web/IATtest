private struct CustomSheetView: View {
    @Binding var isPresented: Bool
    @Binding var positiveText: String
    @Binding var negativeText: String
    @Binding var yyText: String
    @Binding var zzText: String
    @Binding var presets: [CustomPreset]

    @State private var showHistory: Bool = false
    @State private var selectedPresetId: UUID? = nil

    var body: some View {
        VStack(spacing: 16) {
            HStack {
                Button {
                    isPresented = false
                } label: {
                    Image(systemName: "xmark")
                        .font(.system(size: 16, weight: .semibold))
                }
                Spacer()
            }

            Text("自定义")
                .font(.title2)
                .fontWeight(.semibold)

            VStack(spacing: 12) {
                TextField("正面（输入正面匹配词）", text: $positiveText, axis: .vertical)
                    .textFieldStyle(.roundedBorder)

                TextField("负面（输入负面匹配词）", text: $negativeText, axis: .vertical)
                    .textFieldStyle(.roundedBorder)

                HStack(spacing: 12) {
                    TextField("yy（正面更快）", text: $yyText)
                        .textFieldStyle(.roundedBorder)
                        .disabled(selectedPresetId != nil)
                    TextField("zz（负面更快）", text: $zzText)
                        .textFieldStyle(.roundedBorder)
                        .disabled(selectedPresetId != nil)
                }
            }

            if showHistory {
                List {
                    ForEach(presets) { preset in
                        HStack {
                            Button(preset.displayName) {
                                positiveText = preset.positiveText
                                negativeText = preset.negativeText
                                yyText = preset.yyText
                                zzText = preset.zzText
                                selectedPresetId = preset.id
                            }
                            Spacer()
                            Button {
                                deletePreset(preset)
                            } label: {
                                Image(systemName: "xmark.circle.fill")
                                    .foregroundStyle(.secondary)
                            }
                            .buttonStyle(.plain)
                        }
                    }
                }
                .frame(maxHeight: 220)
            }

            HStack(spacing: 16) {
                Button("历史") {
                    showHistory.toggle()
                }
                .buttonStyle(.bordered)

                Button("确定") {
                    savePreset(closeAfterSave: true)
                }
                .buttonStyle(.borderedProminent)
                .keyboardShortcut(.defaultAction)

                Button("保存") {
                    savePreset(closeAfterSave: true)
                }
                .buttonStyle(.bordered)
            }
        }
        .padding(24)
        .frame(minWidth: 520)
        .onAppear {
            presets = CustomPresetStore.load()
        }
    }

    private func savePreset(closeAfterSave: Bool) {
        let trimmedYY = yyText.trimmingCharacters(in: .whitespacesAndNewlines)
        let trimmedZZ = zzText.trimmingCharacters(in: .whitespacesAndNewlines)
        var updated = presets
        if let selectedId = selectedPresetId,
           let index = updated.firstIndex(where: { $0.id == selectedId }) {
            updated[index].positiveText = positiveText
            updated[index].negativeText = negativeText
            updated[index].updatedAt = Date()
        } else {
            let preset = CustomPreset(
                id: UUID(),
                positiveText: positiveText,
                negativeText: negativeText,
                yyText: trimmedYY,
                zzText: trimmedZZ,
                updatedAt: Date()
            )
            updated.insert(preset, at: 0)
            selectedPresetId = preset.id
        }
        presets = updated
        CustomPresetStore.save(updated)
        if closeAfterSave {
            isPresented = false
        }
    }

    private func deletePreset(_ preset: CustomPreset) {
        presets.removeAll { $0.id == preset.id }
        if selectedPresetId == preset.id {
            selectedPresetId = nil
        }
        CustomPresetStore.save(presets)
    }
}

private struct TaskView: View {
    @State var session: IATSession
    @State private var blockIndex: Int = 0
    @State private var trialIndex: Int = 0
    @State private var showError: Bool = false
    @State private var trialStartTime: UInt64 = 0
    @State private var firstKey: String? = nil
    @State private var showReport: Bool = false
    @State private var showBlockIntro: Bool = false
    @State private var highlightCorrect: Bool = false
    @State private var isTransitioning: Bool = false
    @State private var elapsedMs: Double = 0
    @State private var timerTask: Task<Void, Never>? = nil

    var body: some View {
        let block = session.blocks[blockIndex]
        let safeTrialIndex = min(trialIndex, max(block.trials.count - 1, 0))

        VStack(spacing: 16) {
            HStack(alignment: .top) {
                Text(block.leftLabel)
                    .frame(maxWidth: .infinity, alignment: .leading)

                VStack(spacing: 4) {
                    Text(String(format: "%.0f ms", elapsedMs))
                        .font(.system(size: 18, weight: .semibold))
                        .foregroundStyle(.red)
                    Text("本轮剩余关键词：\(block.trials.count - trialIndex)")
                        .font(.system(size: 16))
                        .foregroundStyle(.secondary)
                }
                .frame(maxWidth: .infinity)

                Text(block.rightLabel)
                    .frame(maxWidth: .infinity, alignment: .trailing)
            }
            .font(.system(size: 20, weight: .semibold))
            .padding(.horizontal, 24)

            Spacer()

            if block.trials.isEmpty {
                Text("准备中…")
                    .font(.system(size: 24, weight: .semibold))
            } else {
                Text(block.trials[safeTrialIndex].stimulus)
                .font(.system(size: 56, weight: .bold))
                .foregroundStyle(highlightCorrect ? .green : .primary)
                .padding(.vertical, 16)
            }

            if showError {
                Text("错误，请改正")
                    .foregroundStyle(.red)
            }

            Spacer()

        }
        .padding(24)
        .overlay(alignment: .center) {
            HStack {
                Button("S") {
                    handleKey("S")
                }
                .keyboardShortcut("s", modifiers: [])

                Spacer()

                Button("J") {
                    handleKey("J")
                }
                .keyboardShortcut("j", modifiers: [])
            }
            .buttonStyle(.bordered)
            .padding(.horizontal, 24)
        }
        .overlay {
            VerticalGuidesView()
        }
        .navigationTitle(block.title)
        .navigationBarBackButtonHidden(true)
        .onAppear {
            prepareBlock()
        }
        .onChange(of: trialIndex) { _, _ in
            if !showBlockIntro {
                startTrial()
            }
        }
        .onChange(of: blockIndex) { _, _ in
            trialIndex = 0
            prepareBlock()
        }
        .onDisappear {
            timerTask?.cancel()
        }
        .navigationDestination(isPresented: $showReport) {
            if let report = session.report {
                ReportView(report: report, concept: session.concept, isPreciseMode: session.isPreciseMode)
            }
        }
        .overlay(alignment: .bottomTrailing) {
            Button("跳过（正式版删除）") {
                skipBlock()
            }
            .buttonStyle(.bordered)
            .padding(24)
        }
        .overlay {
            if showBlockIntro {
                BlockIntroOverlay(
                    title: block.title,
                    instruction: blockInstructionText(block: block, concept: session.concept),
                    count: block.trials.count
                ) {
                    showBlockIntro = false
                    startTrial()
                }
            }
        }
    }

    private func prepareBlock() {
        showBlockIntro = true
        showError = false
        firstKey = nil
        highlightCorrect = false
        isTransitioning = false
        elapsedMs = 0
        trialStartTime = 0
        timerTask?.cancel()
    }

    private func startTrial() {
        showError = false
        firstKey = nil
        highlightCorrect = false
        isTransitioning = false
        elapsedMs = 0
        trialStartTime = DispatchTime.now().uptimeNanoseconds
        startTimer()
    }

    private func handleKey(_ key: String) {
        if showBlockIntro || isTransitioning {
            return
        }
        let block = session.blocks[blockIndex]
        let safeTrialIndex = min(trialIndex, max(block.trials.count - 1, 0))
        let trial = block.trials[safeTrialIndex]
        let now = DispatchTime.now().uptimeNanoseconds

        if firstKey == nil {
            firstKey = key
            let rtMs = Double(now - trialStartTime) / 1_000_000.0
            let isCorrect = key == trial.correctKey
            session.recordResponse(
                blockIndex: blockIndex,
                trialIndex: trialIndex,
                firstKey: key,
                isCorrect: isCorrect,
                rtMs: rtMs
            )
            showError = !isCorrect
            if isCorrect {
                highlightCorrect = true
                isTransitioning = true
                DispatchQueue.main.asyncAfter(deadline: .now() + 0.3) {
                    highlightCorrect = false
                    isTransitioning = false
                    advance()
                }
            }
            return
        }

        if showError && key == trial.correctKey {
            showError = false
            highlightCorrect = true
            isTransitioning = true
            DispatchQueue.main.asyncAfter(deadline: .now() + 0.3) {
                highlightCorrect = false
                isTransitioning = false
                advance()
            }
        }
    }

    private func skipBlock() {
        let block = session.blocks[blockIndex]
        for index in trialIndex..<block.trials.count {
            let trial = block.trials[index]
            session.recordResponse(
                blockIndex: blockIndex,
                trialIndex: index,
                firstKey: trial.correctKey,
                isCorrect: true,
                rtMs: 800
            )
        }
        showError = false
        highlightCorrect = false
        isTransitioning = false
        timerTask?.cancel()
        if blockIndex + 1 < session.blocks.count {
            blockIndex += 1
        } else {
            session.finalize()
            showReport = true
        }
    }

    private func advance() {
        let block = session.blocks[blockIndex]
        if trialIndex + 1 < block.trials.count {
            trialIndex += 1
        } else if blockIndex + 1 < session.blocks.count {
            blockIndex += 1
        } else {
            session.finalize()
            showReport = true
        }
    }

    private func blockInstructionText(block: IATBlock, concept: String) -> String {
        switch block.id {
        case 1:
            return "其他按 S，\(concept) 按 J"
        case 2:
            return "正面按 S，负面按 J"
        case 3, 4:
            return "其他和正面按 S，\(concept) 和负面按 J"
        case 5:
            return "\(concept) 按 S，其他按 J"
        case 6, 7:
            return "\(concept) 和正面按 S，其他和负面按 J"
        default:
            return "当出现 \(block.leftLabel) 时按 “S”，当出现 \(block.rightLabel) 时按 “J”。"
        }
    }

    private func startTimer() {
        timerTask?.cancel()
        let startTime = trialStartTime
        timerTask = Task {
            while !Task.isCancelled {
                let now = DispatchTime.now().uptimeNanoseconds
                let ms = Double(now - startTime) / 1_000_000.0
                await MainActor.run {
                    elapsedMs = ms
                }
                try? await Task.sleep(nanoseconds: 16_000_000)
            }
        }
    }
}

