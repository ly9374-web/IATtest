private struct IATSession: Hashable {
    let subjectId: String
    let concept: String
    let seed: UInt64
    let orderCondition: Int
    let positionCondition: Int
    let isPreciseMode: Bool
    let linkPositive: String
    let linkNegative: String

    var blocks: [IATBlock]
    var responses: [TrialResponse]
    var report: IATReport? = nil

    init(concept: String, isPreciseMode: Bool, customConfig: CustomWordConfig?) {
        self.subjectId = UUID().uuidString
        self.concept = concept
        self.seed = UInt64(Date().timeIntervalSince1970 * 1000)
        var rng = SeededRandomNumberGenerator(seed: seed)
        self.isPreciseMode = isPreciseMode
        self.orderCondition = Bool.random(using: &rng) ? 1 : 2
        self.positionCondition = Bool.random(using: &rng) ? 1 : 2
        self.linkPositive = customConfig?.yyText.isEmpty == false ? customConfig?.yyText ?? "喜欢" : "喜欢"
        self.linkNegative = customConfig?.zzText.isEmpty == false ? customConfig?.zzText ?? "不喜欢" : "不喜欢"
        self.blocks = []
        self.responses = []

        let stimuli = StimulusBank(concept: concept, customConfig: customConfig)
        self.blocks = IATBlockFactory.makeBlocks(
            stimuli: stimuli,
            orderCondition: orderCondition,
            positionCondition: positionCondition,
            rng: &rng
        )
        for blockIndex in blocks.indices {
            for trialIndex in blocks[blockIndex].trials.indices {
                responses.append(TrialResponse(blockIndex: blockIndex, trialIndex: trialIndex))
            }
        }
    }

    mutating func recordResponse(blockIndex: Int, trialIndex: Int, firstKey: String, isCorrect: Bool, rtMs: Double) {
        if let index = responses.firstIndex(where: { $0.blockIndex == blockIndex && $0.trialIndex == trialIndex }) {
            responses[index].firstKey = firstKey
            responses[index].isCorrect = isCorrect
            responses[index].rtMs = rtMs
        }
    }

    mutating func finalize() {
        let report = IATReport.generate(
            subjectId: subjectId,
            concept: concept,
            linkPositive: linkPositive,
            linkNegative: linkNegative,
            seed: seed,
            orderCondition: orderCondition,
            positionCondition: positionCondition,
            blocks: blocks,
            responses: responses
        )
        self.report = report
    }
}

