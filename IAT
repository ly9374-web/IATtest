private struct ScatterPlotView: View {
    let points: [ScatterPoint]

    var body: some View {
        GeometryReader { proxy in
            let maxX = max(points.map { $0.x }.max() ?? 1, 1)
            let minX = min(points.map { $0.x }.min() ?? 0, 0)
            let width = proxy.size.width
            let height = proxy.size.height
            Canvas { context, _ in
                let axisPath = Path { path in
                    path.move(to: CGPoint(x: 32, y: height - 24))
                    path.addLine(to: CGPoint(x: width - 8, y: height - 24))
                    path.move(to: CGPoint(x: 32, y: 8))
                    path.addLine(to: CGPoint(x: 32, y: height - 24))
                }
                context.stroke(axisPath, with: .color(.secondary), lineWidth: 1)

                for point in points {
                    let xRatio = (point.x - minX) / (maxX - minX == 0 ? 1 : maxX - minX)
                    let x = 32 + xRatio * (width - 40)
                    let yBase: CGFloat = point.condition == .compatible ? height * 0.35 : height * 0.7
                    let jitter = CGFloat(point.jitter) * 12
                    let center = CGPoint(x: x, y: yBase + jitter)
                    let dotRect = CGRect(x: center.x - 3, y: center.y - 3, width: 6, height: 6)
                    context.fill(Path(ellipseIn: dotRect), with: .color(point.condition == .compatible ? .green : .red))
                }
            }
        }
    }
}

