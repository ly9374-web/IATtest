private enum IATBlockFactory {
    static func makeBlocks(
        stimuli: StimulusBank,
        orderCondition: Int,
        positionCondition: Int,
        rng: inout SeededRandomNumberGenerator
    ) -> [IATBlock] {
        let targetLeftFirst = positionCondition == 1

        let block1 = makeTargetPractice(stimuli: stimuli, targetLeft: targetLeftFirst, rng: &rng)
        let block2 = makeAttributePractice(stimuli: stimuli, rng: &rng)

        let compatibleBlocks: [IATBlock] = [
            makeCombinedPractice(stimuli: stimuli, targetLeft: targetLeftFirst, compatible: true, rng: &rng),
            makeCombinedFormal(stimuli: stimuli, targetLeft: targetLeftFirst, compatible: true, rng: &rng)
        ]

        let targetSwap = makeTargetSwapPractice(stimuli: stimuli, targetLeft: !targetLeftFirst, rng: &rng)

        let incompatibleBlocks: [IATBlock] = [
            makeCombinedPractice(stimuli: stimuli, targetLeft: !targetLeftFirst, compatible: false, rng: &rng),
            makeCombinedFormal(stimuli: stimuli, targetLeft: !targetLeftFirst, compatible: false, rng: &rng)
        ]

        return [block1, block2] + compatibleBlocks + [targetSwap] + incompatibleBlocks
    }

    private static func makeTargetPractice(
        stimuli: StimulusBank,
        targetLeft: Bool,
        rng: inout SeededRandomNumberGenerator
    ) -> IATBlock {
        let leftLabel = "其他"
        let rightLabel = stimuli.concept
        let trials = makeTrials(
            stimuli: stimuli,
            counts: [(.target, 4), (.neutral, 4)],
            leftCategories: [.neutral],
            rng: &rng,
            avoidRepeat: false
        )
        return IATBlock(id: 1, title: "Block 1：目标分类练习", leftLabel: leftLabel, rightLabel: rightLabel, type: .targetPractice, trials: trials)
    }

    private static func makeAttributePractice(
        stimuli: StimulusBank,
        rng: inout SeededRandomNumberGenerator
    ) -> IATBlock {
        let trials = makeTrials(
            stimuli: stimuli,
            counts: [(.positive, 4), (.negative, 4)],
            leftCategories: [.positive],
            rng: &rng,
            avoidRepeat: false
        )
        return IATBlock(id: 2, title: "Block 2：属性分类练习", leftLabel: "正面", rightLabel: "负面", type: .attributePractice, trials: trials)
    }

    private static func makeCombinedPractice(
        stimuli: StimulusBank,
        targetLeft: Bool,
        compatible: Bool,
        rng: inout SeededRandomNumberGenerator
    ) -> IATBlock {
        let isCompatible = compatible
        let leftLabel: String
        let rightLabel: String
        let leftCats: Set<StimulusCategory>
        if isCompatible {
            leftLabel = "其他 + 正面"
            rightLabel = "\(stimuli.concept) + 负面"
            leftCats = [.neutral, .positive]
        } else {
            leftLabel = "\(stimuli.concept) + 正面"
            rightLabel = "其他 + 负面"
            leftCats = [.target, .positive]
        }
        let counts: [(StimulusCategory, Int)] = [(.target, 3), (.neutral, 3), (.positive, 2), (.negative, 2)]
        let trials = makeTrials(
            stimuli: stimuli,
            counts: counts,
            leftCategories: leftCats,
            rng: &rng,
            avoidRepeat: true
        )
        return IATBlock(id: isCompatible ? 3 : 6, title: isCompatible ? "Block 3：兼容联合练习" : "Block 6：不兼容联合练习", leftLabel: leftLabel, rightLabel: rightLabel, type: isCompatible ? .compatiblePractice : .incompatiblePractice, trials: trials)
    }

    private static func makeCombinedFormal(
        stimuli: StimulusBank,
        targetLeft: Bool,
        compatible: Bool,
        rng: inout SeededRandomNumberGenerator
    ) -> IATBlock {
        let isCompatible = compatible
        let leftLabel: String
        let rightLabel: String
        let leftCats: Set<StimulusCategory>
        if isCompatible {
            leftLabel = "其他 + 正面"
            rightLabel = "\(stimuli.concept) + 负面"
            leftCats = [.neutral, .positive]
        } else {
            leftLabel = "\(stimuli.concept) + 正面"
            rightLabel = "其他 + 负面"
            leftCats = [.target, .positive]
        }
        let counts: [(StimulusCategory, Int)] = [(.target, 4), (.neutral, 4), (.positive, 4), (.negative, 3)]
        let trials = makeTrials(
            stimuli: stimuli,
            counts: counts,
            leftCategories: leftCats,
            rng: &rng,
            avoidRepeat: true
        )
        return IATBlock(id: isCompatible ? 4 : 7, title: isCompatible ? "Block 4：兼容联合正式" : "Block 7：不兼容联合正式", leftLabel: leftLabel, rightLabel: rightLabel, type: isCompatible ? .compatibleFormal : .incompatibleFormal, trials: trials)
    }

    private static func makeTargetSwapPractice(
        stimuli: StimulusBank,
        targetLeft: Bool,
        rng: inout SeededRandomNumberGenerator
    ) -> IATBlock {
        let leftLabel = stimuli.concept
        let rightLabel = "其他"
        let trials = makeTrials(
            stimuli: stimuli,
            counts: [(.target, 5), (.neutral, 5)],
            leftCategories: [.target],
            rng: &rng,
            avoidRepeat: false
        )
        return IATBlock(id: 5, title: "Block 5：目标换位练习", leftLabel: leftLabel, rightLabel: rightLabel, type: .targetSwapPractice, trials: trials)
    }

    private static func makeTrials(
        stimuli: StimulusBank,
        counts: [(StimulusCategory, Int)],
        leftCategories: Set<StimulusCategory>,
        rng: inout SeededRandomNumberGenerator,
        avoidRepeat: Bool
    ) -> [IATTrial] {
        var trials: [IATTrial] = []
        for (category, count) in counts {
            for _ in 0..<count {
                let stimulus = pickStimulus(stimuli: stimuli, category: category, rng: &rng)
                let correctKey = leftCategories.contains(category) ? "S" : "J"
                trials.append(IATTrial(stimulus: stimulus, category: category, correctKey: correctKey))
            }
        }
        trials.shuffle(using: &rng)
        if avoidRepeat {
            return shuffleAvoidingConsecutiveSameStimulus(trials, rng: &rng)
        }
        return trials
    }

    private static func shuffleAvoidingConsecutiveSameStimulus(
        _ trials: [IATTrial],
        rng: inout SeededRandomNumberGenerator
    ) -> [IATTrial] {
        var result = trials
        for _ in 0..<20 {
            result.shuffle(using: &rng)
            if !hasConsecutiveRepeat(result) {
                return result
            }
            for index in 1..<result.count {
                if result[index].stimulus == result[index - 1].stimulus {
                    if let swapIndex = (index + 1..<result.count).first(where: { candidate in
                        let current = result[index].stimulus
                        let previous = result[index - 1].stimulus
                        let next = candidate + 1 < result.count ? result[candidate + 1].stimulus : ""
                        return result[candidate].stimulus != current && result[candidate].stimulus != previous && next != current
                    }) {
                        result.swapAt(index, swapIndex)
                    }
                }
            }
            if !hasConsecutiveRepeat(result) {
                return result
            }
        }
        return result
    }

    private static func hasConsecutiveRepeat(_ trials: [IATTrial]) -> Bool {
        guard trials.count > 1 else { return false }
        for index in 1..<trials.count where trials[index].stimulus == trials[index - 1].stimulus {
            return true
        }
        return false
    }

    private static func pickStimulus(
        stimuli: StimulusBank,
        category: StimulusCategory,
        rng: inout SeededRandomNumberGenerator
    ) -> String {
        switch category {
        case .target:
            return stimuli.concept
        case .neutral:
            return stimuli.neutrals.randomElement(using: &rng) ?? ""
        case .positive:
            return stimuli.positives.randomElement(using: &rng) ?? ""
        case .negative:
            return stimuli.negatives.randomElement(using: &rng) ?? ""
        }
    }
}

private struct IATReport: Hashable {
    let interpretationText: String
    let compatibleMeanMs: Double
    let incompatibleMeanMs: Double
    let compatibleAccuracy: Double
    let incompatibleAccuracy: Double
    let compatibleFirstErrorRate: Double
    let incompatibleFirstErrorRate: Double
    let dScore: Double
    let scatterPoints: [ScatterPoint]
    let csvText: String
    let jsonText: String

    var compatibleMeanMsString: String { String(format: "%.0f ms", compatibleMeanMs) }
    var incompatibleMeanMsString: String { String(format: "%.0f ms", incompatibleMeanMs) }
    var compatibleAccuracyString: String { String(format: "%.1f%%", compatibleAccuracy * 100) }
    var incompatibleAccuracyString: String { String(format: "%.1f%%", incompatibleAccuracy * 100) }
    var dScoreString: String { String(format: "%.2f", dScore) }
    var compatibleSummaryString: String {
        String(format: "%.0f ms / %.1f%%", compatibleMeanMs, (1 - compatibleAccuracy) * 100)
    }
    var incompatibleSummaryString: String {
        String(format: "%.0f ms / %.1f%%", incompatibleMeanMs, (1 - incompatibleAccuracy) * 100)
    }
    var compatibleFirstErrorRateString: String { String(format: "%.1f%%", compatibleFirstErrorRate * 100) }
    var incompatibleFirstErrorRateString: String { String(format: "%.1f%%", incompatibleFirstErrorRate * 100) }

    static func generate(
        subjectId: String,
        concept: String,
        linkPositive: String,
        linkNegative: String,
        seed: UInt64,
        orderCondition: Int,
        positionCondition: Int,
        blocks: [IATBlock],
        responses: [TrialResponse]
    ) -> IATReport {
        let formalBlocks = [BlockType.compatibleFormal, BlockType.incompatibleFormal]
        var scoredTrials: [ScoredTrial] = []

        for blockIndex in blocks.indices {
            let block = blocks[blockIndex]
            guard formalBlocks.contains(block.type) else { continue }
            for trialIndex in block.trials.indices {
                let trial = block.trials[trialIndex]
                let response = responses.first { $0.blockIndex == blockIndex && $0.trialIndex == trialIndex }
                if let response, let firstKey = response.firstKey, let rtMs = response.rtMs, let isCorrect = response.isCorrect {
                    scoredTrials.append(ScoredTrial(
                        blockType: block.type,
                        stimulus: trial.stimulus,
                        category: trial.category,
                        correctKey: trial.correctKey,
                        firstKey: firstKey,
                        isCorrect: isCorrect,
                        rtMs: rtMs
                    ))
                }
            }
        }

        let cleaned = DataCleaner.clean(trials: scoredTrials)
        let compatibleStats = cleaned.compatible
        let incompatibleStats = cleaned.incompatible

        let compatibleFirstErrorRate = Stats.errorRate(trials: scoredTrials, blockType: .compatibleFormal)
        let incompatibleFirstErrorRate = Stats.errorRate(trials: scoredTrials, blockType: .incompatibleFormal)

        let pooledSd = Stats.pooledStandardDeviation(
            a: compatibleStats.cleanedRts,
            b: incompatibleStats.cleanedRts
        )
        let dScore = pooledSd == 0 ? 0 : (incompatibleStats.mean - compatibleStats.mean) / pooledSd

        let interpretationText: String
        if abs(dScore) < 0.15 {
            interpretationText = "你对 ‘\(concept)’ 的偏好不明显"
        } else if dScore > 0 {
            interpretationText = "你\(linkPositive)\(concept)"
        } else {
            interpretationText = "你\(linkNegative)\(concept)"
        }

        let scatterPoints = cleaned.allTrials.map {
            ScatterPoint(x: $0.rtMs / 1000.0, condition: $0.blockType == .compatibleFormal ? .compatible : .incompatible)
        }

        let export = ExportBuilder.build(
            subjectId: subjectId,
            concept: concept,
            seed: seed,
            orderCondition: orderCondition,
            positionCondition: positionCondition,
            blocks: blocks,
            trials: cleaned.allTrials
        )

        return IATReport(
            interpretationText: interpretationText,
            compatibleMeanMs: compatibleStats.mean,
            incompatibleMeanMs: incompatibleStats.mean,
            compatibleAccuracy: compatibleStats.accuracy,
            incompatibleAccuracy: incompatibleStats.accuracy,
            compatibleFirstErrorRate: compatibleFirstErrorRate,
            incompatibleFirstErrorRate: incompatibleFirstErrorRate,
            dScore: dScore,
            scatterPoints: scatterPoints,
            csvText: export.csv,
            jsonText: export.json
        )
    }
}

private struct ScoredTrial: Hashable {
    let blockType: BlockType
    let stimulus: String
    let category: StimulusCategory
    let correctKey: String
    let firstKey: String
    let isCorrect: Bool
    let rtMs: Double
}

private struct CleanedTrial: Hashable {
    let blockType: BlockType
    let stimulus: String
    let category: StimulusCategory
    let correctKey: String
    let firstKey: String
    let isCorrect: Bool
    let rtMs: Double
    let isExtreme: Bool
    let isExcluded: Bool
    let cleanedRtMs: Double?
}

private enum ConditionType {
    case compatible
    case incompatible
}

private struct ScatterPoint: Hashable {
    let x: Double
    let condition: ConditionType
    let jitter: Double

    init(x: Double, condition: ConditionType) {
        self.x = x
        self.condition = condition
        self.jitter = Double.random(in: -0.5...0.5)
    }
}

private enum DataCleaner {
    static func clean(trials: [ScoredTrial]) -> CleanedSet {
        let compatibleTrials = trials.filter { $0.blockType == .compatibleFormal }
        let incompatibleTrials = trials.filter { $0.blockType == .incompatibleFormal }

        let cleanedCompatible = cleanBlock(trials: compatibleTrials)
        let cleanedIncompatible = cleanBlock(trials: incompatibleTrials)

        let allTrials = cleanedCompatible.trials + cleanedIncompatible.trials

        return CleanedSet(
            compatible: cleanedCompatible.stats,
            incompatible: cleanedIncompatible.stats,
            allTrials: allTrials
        )
    }

    private static func cleanBlock(trials: [ScoredTrial]) -> (trials: [CleanedTrial], stats: BlockStats) {
        var cleaned: [CleanedTrial] = []
        let correctTrials = trials.filter { $0.isCorrect && $0.rtMs >= 200 && $0.rtMs <= 2000 }
        let meanCorrect = Stats.mean(correctTrials.map { $0.rtMs })

        for trial in trials {
            let isExtreme = trial.rtMs < 200 || trial.rtMs > 2000
            let cleanedRt: Double?
            if isExtreme {
                cleanedRt = nil
            } else if trial.isCorrect {
                cleanedRt = trial.rtMs
            } else {
                cleanedRt = meanCorrect + 400
            }
            let cleanedTrial = CleanedTrial(
                blockType: trial.blockType,
                stimulus: trial.stimulus,
                category: trial.category,
                correctKey: trial.correctKey,
                firstKey: trial.firstKey,
                isCorrect: trial.isCorrect,
                rtMs: trial.rtMs,
                isExtreme: isExtreme,
                isExcluded: isExtreme,
                cleanedRtMs: cleanedRt
            )
            cleaned.append(cleanedTrial)
        }

        let stats = BlockStats(
            cleanedRts: cleaned.compactMap { $0.cleanedRtMs },
            accuracy: Stats.accuracy(trials: trials)
        )

        return (cleaned, stats)
    }
}

private struct CleanedSet: Hashable {
    let compatible: BlockStats
    let incompatible: BlockStats
    let allTrials: [CleanedTrial]
}

private struct BlockStats: Hashable {
    let cleanedRts: [Double]
    let accuracy: Double

    var mean: Double { Stats.mean(cleanedRts) }
}

private enum Stats {
    static func mean(_ values: [Double]) -> Double {
        guard !values.isEmpty else { return 0 }
        return values.reduce(0, +) / Double(values.count)
    }

    static func standardDeviation(_ values: [Double]) -> Double {
        guard values.count > 1 else { return 0 }
        let mean = mean(values)
        let variance = values.reduce(0) { $0 + pow($1 - mean, 2) } / Double(values.count - 1)
        return sqrt(variance)
    }

    static func pooledStandardDeviation(a: [Double], b: [Double]) -> Double {
        let aCount = Double(a.count)
        let bCount = Double(b.count)
        guard aCount > 1, bCount > 1 else { return 0 }
        let aVar = pow(standardDeviation(a), 2)
        let bVar = pow(standardDeviation(b), 2)
        let pooled = ((aCount - 1) * aVar + (bCount - 1) * bVar) / (aCount + bCount - 2)
        return sqrt(pooled)
    }

    static func accuracy(trials: [ScoredTrial]) -> Double {
        guard !trials.isEmpty else { return 0 }
        let correct = trials.filter { $0.isCorrect }.count
        return Double(correct) / Double(trials.count)
    }

    static func errorRate(trials: [ScoredTrial], blockType: BlockType) -> Double {
        let filtered = trials.filter { $0.blockType == blockType }
        guard !filtered.isEmpty else { return 0 }
        let incorrect = filtered.filter { !$0.isCorrect }.count
        return Double(incorrect) / Double(filtered.count)
    }
}

private enum ExportBuilder {
    static func build(
        subjectId: String,
        concept: String,
        seed: UInt64,
        orderCondition: Int,
        positionCondition: Int,
        blocks: [IATBlock],
        trials: [CleanedTrial]
    ) -> (csv: String, json: String) {
        var csvLines: [String] = []
        csvLines.append("subjectId,timestamp,seed,orderCondition,positionCondition,blockId,blockType,stimulus,category,correctKey,firstKey,isCorrect,rtMs,isExtreme,isExcluded")

        let timestamp = ISO8601DateFormatter().string(from: Date())
        let jsonTrials: [ExportTrial] = trials.enumerated().map { index, trial in
            let blockId = blockIdForType(blocks: blocks, type: trial.blockType)
            csvLines.append([
                subjectId,
                timestamp,
                String(seed),
                String(orderCondition),
                String(positionCondition),
                String(blockId),
                trial.blockType.rawValue,
                trial.stimulus,
                categoryString(category: trial.category, concept: concept),
                trial.correctKey,
                trial.firstKey,
                String(trial.isCorrect),
                String(format: "%.0f", trial.rtMs),
                String(trial.isExtreme),
                String(trial.isExcluded)
            ].joined(separator: ","))

            return ExportTrial(
                subjectId: subjectId,
                timestamp: timestamp,
                seed: seed,
                orderCondition: orderCondition,
                positionCondition: positionCondition,
                blockId: blockId,
                blockType: trial.blockType.rawValue,
                stimulus: trial.stimulus,
                category: categoryString(category: trial.category, concept: concept),
                correctKey: trial.correctKey,
                firstKey: trial.firstKey,
                isCorrect: trial.isCorrect,
                rtMs: Int(trial.rtMs),
                isExtreme: trial.isExtreme,
                isExcluded: trial.isExcluded
            )
        }

        let csv = csvLines.joined(separator: "\n")
        let jsonData = (try? JSONEncoder().encode(jsonTrials)) ?? Data()
        let json = String(data: jsonData, encoding: .utf8) ?? "[]"
        return (csv, json)
    }

    private static func blockIdForType(blocks: [IATBlock], type: BlockType) -> Int {
        if let match = blocks.first(where: { $0.type == type }) {
            return match.id
        }
        return 0
    }

    private static func categoryString(category: StimulusCategory, concept: String) -> String {
        switch category {
        case .target:
            return concept
        case .neutral:
            return "其他"
        case .positive:
            return "正"
        case .negative:
            return "负"
        }
    }
}

private struct ExportTrial: Codable, Hashable {
    let subjectId: String
    let timestamp: String
    let seed: UInt64
    let orderCondition: Int
    let positionCondition: Int
    let blockId: Int
    let blockType: String
    let stimulus: String
    let category: String
    let correctKey: String
    let firstKey: String
    let isCorrect: Bool
    let rtMs: Int
    let isExtreme: Bool
    let isExcluded: Bool
}

private struct SeededRandomNumberGenerator: RandomNumberGenerator {
    private var state: UInt64

    init(seed: UInt64) {
        self.state = seed == 0 ? 0x1234567890abcdef : seed
    }

    mutating func next() -> UInt64 {
        state = 2862933555777941757 &* state &+ 3037000493
        return state
    }
}

