private struct VerticalGuidesView: View {
    var body: some View {
        GeometryReader { proxy in
            let width = proxy.size.width
            let height = proxy.size.height
            let leftX = width * 0.35
            let rightX = width * 0.65
            Canvas { context, _ in
                var path = Path()
                path.move(to: CGPoint(x: leftX, y: 0))
                path.addLine(to: CGPoint(x: leftX, y: height))
                path.move(to: CGPoint(x: rightX, y: 0))
                path.addLine(to: CGPoint(x: rightX, y: height))
                context.stroke(
                    path,
                    with: .color(.secondary.opacity(0.6)),
                    style: StrokeStyle(lineWidth: 1, dash: [6, 6])
                )
            }
        }
        .allowsHitTesting(false)
    }
}

private struct ReportView: View {
    let report: IATReport
    let concept: String
    let isPreciseMode: Bool

    var body: some View {
        ScrollView {
            VStack(alignment: .leading, spacing: 20) {
                VStack(alignment: .leading, spacing: 8) {
                    Text("结果解释")
                        .font(.headline)
                    Text(report.interpretationText)
                        .font(.title3)
                        .fontWeight(.bold)
                        .foregroundStyle(.green)
                    Text("兼容正式首此眼动错误概率：\(report.compatibleFirstErrorRateString)")
                        .font(.system(size: 18))
                        .foregroundStyle(.secondary)
                    Text("不兼容正式首此眼动错误概率：\(report.incompatibleFirstErrorRateString)")
                        .font(.system(size: 18))
                        .foregroundStyle(.secondary)
                }

                VStack(alignment: .leading, spacing: 8) {
                    Text("统计数据")
                        .font(.headline)
                    StatRow(title: "兼容表情变化度", value: "待定")
                    StatRow(title: "不兼容表情变化度", value: "待定")
                    StatRow(title: "兼容正确率", value: report.compatibleAccuracyString)
                    StatRow(title: "不兼容正确率", value: report.incompatibleAccuracyString)
                    StatRow(title: "当 \(concept) 与正面词汇配对时你的反应速度/错误率", value: report.compatibleSummaryString)
                    StatRow(title: "当 \(concept) 与负面词汇配对时你的反应速度/错误率", value: report.incompatibleSummaryString)
                    StatRow(title: "D 值", value: dScoreDisplayText)
                }

                VStack(alignment: .leading, spacing: 8) {
                    Text("散点图")
                        .font(.headline)
                    ScatterPlotView(points: report.scatterPoints)
                        .frame(height: 240)
                }

                ExportView(csv: report.csvText, json: report.jsonText)
            }
            .padding(24)
        }
        .navigationTitle("报告")
    }

    private var dScoreDisplayText: String {
        if isPreciseMode {
            let absD = abs(report.dScore)
            let label: String
            if absD < 0.15 {
                label = "无明显偏好"
            } else if absD < 0.35 {
                label = "轻微偏好"
            } else if absD < 0.65 {
                label = "中等偏好"
            } else {
                label = "强偏好"
            }
            return String(format: "|D|：%.2f (%@)", absD, label)
        }
        return report.dScoreString
    }
}

